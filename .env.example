# Google Tools — fill with your own IDs.
# Local dev:   copy this file to .env.local and fill in the values, then restart `npm run dev`.
# Production:  add the same variables in Vercel → Project → Settings → Environment Variables.
# (All are optional — each tracker loads only if its variable is set.)

# Google Analytics 4 — Measurement ID
NEXT_PUBLIC_GA_ID=

# Google Tag Manager — Container ID (use this as the hub; you can load GA4 inside GTM)
NEXT_PUBLIC_GTM_ID=

# Google Search Console — site verification token (meta-tag method)
# Alternatively verify the domain via a TXT record in Cloudflare DNS and leave this blank.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
